# Mandatory environment variables for Open3E
# Copy this file to .env and fill in your actual values


# Best do not change the following 3 values unless you are also changing the HA integration configuration
LISTENTOPIC=open3e/cmnd
TOPIC=open3e
FORMATSTRING={device}_{ecuAddr:03X}_{didNumber}_{didName}


# CAN interface name (e.g., can0, vcan0)
CAN=can0

# MQTT Client Configuration
CLIENTID=open3e

# MQTT Broker Configuration
MQTT_HOST=mosquitto
MQTT_USER=mqtt_user
MQTT_PASSWORD=mqtt_password
