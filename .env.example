# Mandatory environment variables for Open3E
# Copy this file to .env and fill in your actual values

# CAN interface name (e.g., can0, vcan0)
CAN=can0

# MQTT Topics
LISTENTOPIC=open3e/listen
TOPIC=open3e/server
FORMATSTRING=open3e/{id}

# MQTT Client Configuration
CLIENTID=open3e

# MQTT Broker Configuration
MQTT_HOST=mosquitto
MQTT_USER=mqtt_user
MQTT_PASSWORD=mqtt_password
